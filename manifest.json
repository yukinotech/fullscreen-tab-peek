{
  "manifest_version": 3,
  "name": "Fullscreen Tab Peek",
  "description": "Reveal a PotPlayer-style tab strip from the left or right edge while Chrome is fullscreen.",
  "version": "0.1.0",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "permissions": ["storage", "tabs", "windows"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "options/index.html",
  "action": {
    "default_title": "Fullscreen Tab Peek",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
